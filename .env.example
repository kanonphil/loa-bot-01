# 디스코드 봇 토큰 (Discord 개발자 포털에서 발급)
DISCORD_TOKEN=your_discord_bot_token_here

# ※ 로스트아크 API 키는 유저별로 /api등록 명령어로 등록합니다.
#   서버 레벨의 API 키는 더 이상 필요하지 않습니다.

# 관리자 앱(Electron)이 쓰는 관리자 API 키
ADMIN_API_KEY=changeme

# 별도 웹 서버(webapp/)가 /api/internal 호출에 쓰는 전용 키.
# ADMIN_API_KEY와 다른 값으로 설정 — 웹앱은 관리자 권한을 가지면 안 됨.
WEBAPP_API_KEY=changeme-webapp

# 게스트(API 키 미등록자) 초대 시 캐릭터 정보 조회에 쓸 API 키의 소유자 discord_id.
# 이 유저가 /api등록으로 등록해둔 키를 재사용해서 게스트가 입력한 캐릭터명을 조회한다.
# 비워두면 게스트 초대 기능이 조회 실패 안내와 함께 동작하지 않는다.
GUEST_LOOKUP_DISCORD_ID=
