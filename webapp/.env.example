# Discord 개발자 포털 → 기존 봇 애플리케이션 → OAuth2 탭에서 발급
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# 로컬 개발: http://localhost:8001/callback
# 실서비스: https://your-domain/callback (Discord 개발자 포털의 Redirects에도 동일하게 등록 필요)
DISCORD_REDIRECT_URI=http://localhost:8001/callback

# 봇 서버(다른 머신)의 주소와, 그 서버 .env의 WEBAPP_API_KEY와 동일한 값
BOT_API_BASE_URL=http://localhost:8000
BOT_API_WEBAPP_KEY=changeme-webapp

# 세션 쿠키 서명용 — 실서비스에서는 반드시 무작위 긴 문자열로 교체
SESSION_SECRET=change-this-to-a-random-string
# 로컬(http)=false, Cloudflare 뒤 실서비스(https)=true
SESSION_HTTPS_ONLY=false

# ── AI 채팅 기록 (선택 — 안 넣으면 아래 기본값 사용) ─────────
# 봇 서버 DB와는 별도 파일. webapp 프로세스 소유.
CHAT_DB_PATH=webapp_chat_history.db
# 이 기간(일)이 지난 대화는 자동 삭제됨
CHAT_RETENTION_DAYS=30

# ── Gemini API (AI 상담, 무료 티어) ──────────────────────────
# https://aistudio.google.com/apikey 에서 발급 (구글 계정만 있으면 됨, 카드 필요 없음)
# 비워두면 AI 상담만 안내 메시지로 대체되고 나머지 기능은 정상 동작
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
